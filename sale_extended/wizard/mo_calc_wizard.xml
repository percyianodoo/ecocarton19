<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_mo_calculation_wizard_form" model="ir.ui.view">
        <field name="name">mo.calculation.wizard.form</field>
        <field name="model">mo.calculation.wizard</field>
        <field name="arch" type="xml">
            <form string="MO Calculations">

                <sheet>
                    <group>
                        <field name="calc_id" readonly="1"/>
                    </group>
                    <field name="line_ids">
                        <list editable="bottom">
                            <field name="production_id"/>
                            <field name="product_id"/>
                            <field name="bom_id"/>
                            <field name="product_qty"/>
                            <field name="formula" readonly="0"/>
<!--                            <field name="result_qty"/>-->
                        </list>
                    </field>
                </sheet>
                <footer>
                    <button name="action_recalculate"
                        type="object"
                        string="Recalculate"
                        class="btn-primary"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
