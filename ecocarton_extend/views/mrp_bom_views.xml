<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <record id="view_mrp_bom_form_inherit_category" model="ir.ui.view">
        <field name="name">mrp.bom.form.inherit.category</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.mrp_bom_form_view"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='bom_line_ids']/list/field[@name='product_id']" position="after">
                <field name="custom_product_category_id"/>
            </xpath>

        </field>
    </record>
</odoo>