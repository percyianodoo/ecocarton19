<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <template id="portal_my_home_po_upload"
              inherit_id="portal.portal_my_home"
              name="PO Upload Card"
              customize_show="True"
              priority="30">
        <!-- Enable Portal Category -->
        <xpath expr="//div[hasclass('o_portal_docs')]" position="before">
            <t t-set="portal_client_category_enable" t-value="True"/>
        </xpath>
        <!-- Add Card -->
        <xpath expr="//div[@id='portal_client_category']" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="icon" t-value="'/account/static/src/img/bill.svg'"/>
                <t t-set="title">PO Upload</t>
                <t t-set="url" t-value="'/my/po_upload'"/>
                <t t-set="text">
                    Upload your Purchase Order PDFs
                </t>
                <t t-set="placeholder_count" t-value="'po_count'"/>
            </t>
        </xpath>
    </template>


    <!-- Upload Page -->
    <template id="portal_po_upload_page" name="Portal PO Upload">
        <t t-call="portal.portal_layout">
            <div class="container mt-4 mb-5">
                <div class="row">
                    <div class="col-lg-8 offset-lg-2">
                        <div class="card">
                            <div class="card-header">
                                <h3>Upload Purchase Orders</h3>
                            </div>
                            <div class="card-body">
                                <form action="/my/po_upload/submit" method="post" enctype="multipart/form-data">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <div class="mb-3">
                                        <label class="form-label">
                                            Select PO PDFs
                                        </label>
                                        <input type="file" name="po_files" multiple="multiple" accept=".pdf"
                                               class="form-control" required="required"/>
                                    </div>
                                    <button type="submit" class="btn btn-primary">
                                        Upload
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>