<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_portal_po_upload_tree" model="ir.ui.view">
        <field name="name">portal.po.upload.tree</field>
        <field name="model">portal.po.upload</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="uploaded_by"/>
                <field name="create_date"/>
                <field name="is_proceed"/>
                <field name="attachment_ids" widget="many2many_binary"/>
                <field name="sale_order_id"/>
                <field name="remark"/>
            </list>
        </field>
    </record>

    <record id="view_portal_po_upload_form" model="ir.ui.view">
        <field name="name">portal.po.upload.form</field>
        <field name="model">portal.po.upload</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="uploaded_by" readonly="1"/>
                        </group>
                        <group>
                            <field name="create_date" readonly="1"/>
                            <field name="is_proceed"/>
                            <field name="sale_order_id" readonly="1"/>
                            <field name="remark"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Uploaded Files">
                            <field name="attachment_ids" widget="many2many_binary"/>
                        </page>
                        <page string="Raw Data">
                            <field name="raw_payload" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_portal_po_upload" model="ir.actions.act_window">
        <field name="name">PO Uploads</field>
        <field name="res_model">portal.po.upload</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
            id="menu_portal_po_upload"
            name="PO Uploads"
            parent="sale.sale_menu_root"
            action="action_portal_po_upload"
            sequence="90"
    />

</odoo>