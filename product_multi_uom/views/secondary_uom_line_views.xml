<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_secondary_uom_line_view_form" model="ir.ui.view">
        <field name="name">secondary.uom.line.view.form</field>
        <field name="model">secondary.uom.line</field>
        <field name="arch" type="xml">
            <form string="Secondary UoM Line">
                <sheet>
                    <group>
                        <field name="secondary_uom_id" options='{"no_create": True, "no_create_edit": True}' required="1" domain="[('id', 'in', uom_ids)]"/>
                        <field name="secondary_uom_ratio"/>
                        <field name="example_ratio"/>
                    </group>
                    <group>
                        <field name="product_id" invisible="1"/>
                        <field name="product_template_id" invisible="1"/>
                        <field name="uom_ids" widget="many2many_tags" readonly="1" invisible="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
